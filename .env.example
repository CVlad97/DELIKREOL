# =============================================================================
# DELIKREOL — Configuration d'environnement (copier vers .env)
# =============================================================================
# Usage: cp .env.example .env
# Toutes les variables préfixées VITE_ sont exposées côté client.
# Ne JAMAIS mettre de clés secrètes (service_role, STRIPE_SECRET) ici.
# =============================================================================

# ── Supabase (obligatoire) ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ...

# ── Stripe (obligatoire pour les paiements) ─────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# ── WhatsApp (obligatoire pour les commandes) ───────────────────────────────
VITE_WHATSAPP_NUMBER=596696653589

# ── Blink (paiement instantané) ─────────────────────────────────────────────
VITE_BLINK_PROJECT_ID=proj_xxxxxxxxxxxxxxxx
VITE_BLINK_PUBLISHABLE_KEY=pk_blink_xxxxxxxxxxxxxxxxxxxx

# ── Google SSO (connexion) ──────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# ── Paiement bancaire (virement) ────────────────────────────────────────────
VITE_BANK_PAYMENT_URL=https://example.com/payer
VITE_BANK_IBAN=FR76XXXXXXXXXXXXXXX
VITE_BANK_BIC=XXXXXXXXXXX
VITE_BANK_PAYMENT_LABEL=Virement DELIKREOL

# ── ERP / API métier ────────────────────────────────────────────────────────
VITE_ERP_API_URL=https://api.delikreol.com
VITE_ERP_FALLBACK_DEMO=true

# ── OpenAI (copilot admin) ──────────────────────────────────────────────────
VITE_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Sheets (fallback catalogue / commandes) ──────────────────────────
VITE_SHEETS_PUBLIC_URL=https://docs.google.com/spreadsheets/d/...
VITE_SHEETS_ORDERS_URL=https://docs.google.com/spreadsheets/d/...
VITE_SHEETS_API_URL=https://script.google.com/macros/s/...
VITE_SHEETS_FALLBACK=true

# ── Métriques ───────────────────────────────────────────────────────────────
VITE_METRICS_WEBHOOK_URL=https://hooks.example.com/metrics

# ── Mode démo / feature flags ───────────────────────────────────────────────
VITE_DEMO_MODE=false

# ── Build / déploiement ─────────────────────────────────────────────────────
VITE_BASE_PATH=/DELIKREOL/

# ── Qonto (compte pro Delikreol — BACKEND ONLY, jamais dans le frontend) ─────
# Documentation API : https://docs.qonto.com
# Sandbox : https://docs.qonto.com/sandbox
# QONTO_API_BASE_URL=https://api-doc.qonto.com/v2
# QONTO_CLIENT_ID=votre_client_id
# QONTO_CLIENT_SECRET=votre_client_secret
# QONTO_WEBHOOK_SECRET=secret_pour_webhooks

# ── Stripe (paiements clients → virement vers IBAN Qonto) ─────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
# PAYPAL_CLIENT_ID=xxx
# PAYPAL_SECRET=xxx