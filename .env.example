# DeliKreol — configuration publique frontend
# Copier ce fichier en .env.local pour le developpement local.
# Ne jamais mettre de cle secrete ici : toutes les variables VITE_ sont visibles dans le navigateur.

# Supabase Free / public API
# A recuperer dans Supabase > Project Settings > API
# Lien : https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://boihlgodmclljtckhmgz.supabase.co
VITE_SUPABASE_ANON_KEY=SUPABASE_ANON_KEY_REPLACE_ME  # À récupérer dans Supabase > Project Settings > API

# Mode gratuit par defaut
VITE_FREE_MODE=true
VITE_ORDER_MODE=whatsapp_first
VITE_ERP_FALLBACK_DEMO=true

# Contacts publics officiels DeliKreol
VITE_WHATSAPP_NUMBER=596696653589
VITE_CONTACT_EMAIL=contact@delikreol.mq
VITE_OPERATIONS_EMAIL=contact@delikreol.mq

# Optionnel : Google Sheets / webhook si ajoute plus tard
VITE_METRICS_WEBHOOK_URL=
VITE_SHEETS_PUBLIC_URL=
VITE_SHEETS_API_URL=
VITE_ORDER_FORM_URL=

# Application
VITE_APP_NAME=DeliKreol
VITE_APP_ENV=development

# Paiement — phase 2 uniquement
# Ne jamais mettre de cle Stripe secrete ici.
# Une cle publishable test peut etre ajoutee plus tard si paiement active.
VITE_STRIPE_PUBLISHABLE_KEY=

# Securite critique
# INTERDIT dans ce fichier et dans tout code frontend :
# - SUPABASE_SERVICE_ROLE_KEY
# - STRIPE_SECRET_KEY
# - META_WHATSAPP_TOKEN
# - GITHUB_TOKEN
# - Mot de passe Hostinger
# - Mot de passe email
#
# Les secrets doivent rester dans les dashboards officiels ou Edge Functions, jamais dans GitHub public.
