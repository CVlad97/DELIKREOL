# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://boihlgodmclljtckhmgz.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Public contact / ordering
# Use international format without + for wa.me, example Martinique: 596696000000
VITE_WHATSAPP_NUMBER=596696000000

# Application Configuration
VITE_APP_NAME=Delikreol
VITE_APP_ENV=pilot

# Deployment
# For GitHub Pages, set this when building the public site:
# VITE_BASE_PATH=/DELIKREOL/

# Notes:
# - All variables prefixed with VITE_ are exposed to the browser.
# - Never commit your actual .env file with private credentials.
# - This immediate pilot version uses WhatsApp confirmation and manual payment after validation.
# - Stripe / online payment must stay out of the public pilot until webhook, commission, reconciliation, refund and dispute handling are tested.
# - If Stripe is added later, secret keys must never be placed in VITE_ variables or frontend code.
